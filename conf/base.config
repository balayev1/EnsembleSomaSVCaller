process {
    executor = 'slurm'

    // Default generic resources (optional safety net)
    cpus   = { check_max( 2     * task.attempt, 'cpus'    ) }
    memory = { check_max( 12.GB * task.attempt, 'memory'  ) }
    time   = { check_max( 4.h   * task.attempt, 'time'    ) }

    errorStrategy = { task.exitStatus in [143,140,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'

    withLabel: process_single {
        cpus   = { check_max( 1                  , 'cpus'    ) }
        memory = { check_max( 6.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 4.h  * task.attempt, 'time'    ) }
    }

    withLabel: process_low {
        cpus   = { check_max( 2     * task.attempt, 'cpus'    ) }
        memory = { check_max( 12.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 4.h   * task.attempt, 'time'    ) }
    }
    
    withLabel:process_medium {
        cpus   = { check_max( 6     * task.attempt, 'cpus'    ) }
        memory = { check_max( 36.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 8.h   * task.attempt, 'time'    ) }
    }
    
    withLabel:process_high {
        cpus   = { check_max( 12    * task.attempt, 'cpus'    ) }
        memory = { check_max( 72.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 16.h  * task.attempt, 'time'    ) }
    }

    withName: ASCAT {
        cpus   = { check_max( 8, 'cpus' ) }
        memory = { check_max( 64.GB * task.attempt, 'memory' ) }
        time   = { check_max( 12.h  * task.attempt, 'time'   ) }
    }

    withName: SEQUENZAUTILS_GCWIGGLE {
        cpus   = { check_max( 1, 'cpus' ) }
        memory = { check_max( 32.GB * task.attempt, 'memory' ) }
        time   = { check_max( 12.h  * task.attempt, 'time'   ) }
    }

    withName: SEQUENZA_RUN {
        cpus   = { check_max( 4, 'cpus' ) }
        memory = { check_max( 64.GB * task.attempt, 'memory' ) }
        time   = { check_max( 24.h  * task.attempt, 'time'   ) }
    }

    withName: FACETS {
        cpus   = { check_max( 8, 'cpus' ) }
        memory = { check_max( 64.GB * task.attempt, 'memory' ) }
        time   = { check_max( 12.h  * task.attempt, 'time'   ) }
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:BAM_HETPILEUPS:HETPILEUPS' {
        cpus   = { check_max( 6     * task.attempt, 'cpus'    ) }
        memory = { check_max( 36.GB * task.attempt, 'memory'  ) }
        time   = { check_max( 24.h  * task.attempt, 'time'    ) }
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:BREAKPOINT_ESTIMATOR:BAM_DELLY:DELLY_CALL' {
        cpus   = { check_max( 16, 'cpus' ) }
        memory = { check_max( 128.GB, 'memory' ) }
        time   = { check_max( 24.h, 'time' ) }
    }

    withName: 'FRAGCOUNTER' {
        cpus            = { check_max( 12 * task.attempt, 'cpus' ) }
        memory          = { check_max( 48.GB * task.attempt, 'memory' ) }
        time            = { check_max( 48.h  * task.attempt, 'time'   ) }
    }
    
    withName: 'DRYCLEAN' {
        cpus            = { check_max( 8 * task.attempt, 'cpus' ) }
        memory          = { check_max( 48.GB * task.attempt, 'memory' ) }
        time            = { check_max( 36.h  * task.attempt, 'time'    ) }
    }
}
