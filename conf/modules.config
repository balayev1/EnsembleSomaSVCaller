process {
    withName: BCFTOOLS_ANNOTATE {
        ext.args = '--output-type z --write-index=tbi'
    }

    withName: ASCAT {
        ext.args = { [
            gender: meta.gender,
            genomeVersion: params.ascat_genome,
            minCounts: params.ascat_min_counts,
            min_base_qual: params.ascat_min_basequal,
            min_map_qual: params.ascat_min_mapqual,
        ] }

        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/ascat/${meta.id}" },
        ]
    }

    withName: SEQUENZAUTILS_GCWIGGLE {
        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/sequenza/reference" },
        ]
    }

    withName: SEQUENZA_RUN {
        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/sequenza/${meta.id}" },
        ]
    }

    withName: FACETS {
        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/facets/${meta.id}" },
        ]
    }

    withName: PURITY_PLOIDY_MERGE {
        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/purity_ploidy/${meta.id}" },
        ]
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:BAM_HETPILEUPS:HETPILEUPS' {
        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/hetpileups/${meta.id}" },
        ]
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:BREAKPOINT_ESTIMATOR:BAM_DELLY:DELLY_CALL' {
        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/delly/${meta.id}/call" },
        ]
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:BREAKPOINT_ESTIMATOR:BAM_DELLY:DELLY_FILTER' {
        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/delly/${meta.id}/filter" },
        ]
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:BREAKPOINT_ESTIMATOR:BCFTOOLS_VIEW' {
        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/delly/${meta.id}/view" },
        ]
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:BREAKPOINT_ESTIMATOR:GRIDSS_SV_CALLING:GRIDSS_GRIDSS' {
        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/gridss/${meta.id}/call" },
        ]
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:BREAKPOINT_ESTIMATOR:GRIDSS_SOMATIC_FILTER_STEP:GRIDSS_SOMATIC_FILTER' {
        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/gridss/${meta.id}/filter" },
        ]
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:BREAKPOINT_ESTIMATOR:SVABA' {
        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/svaba/${meta.id}" },
        ]
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:BREAKPOINT_ESTIMATOR:DELLY_VCF_TO_PLAIN' {
        ext.prefix = { "${meta.id}.delly" }
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:BREAKPOINT_ESTIMATOR:GRIDSS_VCF_TO_PLAIN' {
        ext.prefix = { "${meta.id}.gridss" }
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:BREAKPOINT_ESTIMATOR:BRASS_VCF_TO_PLAIN' {
        ext.prefix = { "${meta.id}.brass" }
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:BREAKPOINT_ESTIMATOR:SVABA_VCF_TO_PLAIN' {
        ext.prefix = { "${meta.id}.svaba" }
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:BREAKPOINT_ESTIMATOR:BREAKPOINTS_SURVIVOR_MERGE' {
        ext.prefix = { "${meta.id}.consensus_breakpoints" }

        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/survivor/merge/${meta.id}" },
        ]
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:BREAKPOINT_ESTIMATOR:INDEL_MASK_SLOP' {
        ext.args = '-b 200'
        ext.prefix = { "${meta.id}.blacklist_padded" }
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:BREAKPOINT_ESTIMATOR:FILTER_BLACKLIST_REGIONS' {
        ext.args = '-v -header'
        ext.prefix = { "${meta.id}.consensus_breakpoints_blacklist_filtered" }
        ext.suffix = 'vcf'
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:BREAKPOINT_ESTIMATOR:SURVIVOR_POST_FILTER_PROCESSING' {
        ext.prefix = { "${meta.id}.consensus_breakpoints_filtered" }

        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/survivor/filter/${meta.id}" },
            pattern: "*.consensus_breakpoints_filtered.vcf",
        ]
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:BREAKPOINT_ESTIMATOR:SURVIVOR_BCFTOOLS_REHEADER' {
        ext.args2 = '--output-type v'
        ext.prefix = { "${meta.id}.consensus_breakpoints_filtered.reheader" }
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:BREAKPOINT_ESTIMATOR:TRANSFORM_ASCAT_STATS' {
        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/ascat/${meta.id}/brass_stats" },
        ]
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:BREAKPOINT_ESTIMATOR:NORMAL_BAM_STATS' {
        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/bam_stats/normal/${meta.id}" },
        ]
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:BREAKPOINT_ESTIMATOR:TUMOR_BAM_STATS' {
        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/bam_stats/tumor/${meta.id}" },
        ]
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:BREAKPOINT_ESTIMATOR:BRASS' {
        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/brass/${meta.id}" },
        ]
    }


    withName: 'NFCORE_SOMASV:SOMASV_CALLER:COVERAGE_JABBA:TUMOR_FRAGCOUNTER:FRAGCOUNTER' {
        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/Coverages/fragCounter_tumor/${meta.id}/" },
            pattern: "*{.rds,.bw,cov*,.command.*}"
        ]
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:COVERAGE_JABBA:NORMAL_FRAGCOUNTER:FRAGCOUNTER' {
        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/Coverages/fragCounter_normal/${meta.id}/" },
            pattern: "*{.rds,.bw,cov*,.command.*}"
        ]
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:COVERAGE_JABBA:NORMAL_FRAGCOUNTER:REBIN_RAW_FRAGCOUNTER' {
        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/Coverages/fragCounter_normal/${meta.id}/" },
            pattern: "*{.rds,1kb_*,.command.*}"
        ]
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:COVERAGE_JABBA:TUMOR_FRAGCOUNTER:REBIN_RAW_FRAGCOUNTER' {
        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/Coverages/fragCounter_tumor/${meta.id}/" },
            pattern: "*{.rds,1kb_*,.command.*}"
        ]
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:COVERAGE_JABBA:TUMOR_DRYCLEAN:DRYCLEAN' {
        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/Coverages/Dryclean_tumor/${meta.id}/" },
            pattern: "*{cov.rds,.command.*}"
        ]
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:COVERAGE_JABBA:NORMAL_DRYCLEAN:DRYCLEAN' {
        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/Coverages/Dryclean_normal/${meta.id}/" },
            pattern: "*{cov.rds,.command.*}"
        ]
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:COV_CBS:CBS' {
        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/Coverages/CBS/${meta.id}/" },
        ]
    }

    withName: 'NFCORE_SOMASV:SOMASV_CALLER:JABBA_RUN:JABBA' {
        publishDir = [
            mode: params.publish_dir_mode,
            path: { "${params.outdir}/jabba/${meta.id}" },
        ]
    }
}